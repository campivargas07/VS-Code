# n8n
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
WEBHOOK_URL=http://localhost:5678/webhook/sku-created

# Google Slides
GOOGLE_PRESENTATION_ID=replace_with_presentation_id
GOOGLE_TEMPLATE_SLIDE_OBJECT_ID=replace_with_template_slide_object_id

# Optional: idempotency store (when using external db)
IDEMPOTENCY_ENABLED=true
